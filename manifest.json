{
  "manifest_version": 3,
  "name": "Endpoint Rejector",
  "version": "1.0",
  "description": "Reject specific API endpoints with custom HTTP error codes",
  "permissions": ["storage", "scripting", "activeTab", "declarativeNetRequest"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}
